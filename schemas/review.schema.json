{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_id",
    "reviewer",
    "cycle",
    "summary",
    "main_claims",
    "technical_objections",
    "missing_assumptions",
    "novelty_assessment",
    "recommended_verdict",
    "confidence",
    "followup_notes",
    "needs_human_spotcheck",
    "overall_score_10",
    "dimension_scores",
    "score_rationale"
  ],
  "properties": {
    "paper_id": { "type": "string" },
    "reviewer": { "type": "string" },
    "cycle": { "type": "integer", "minimum": 1 },
    "summary": { "type": "string" },
    "main_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "paper_location", "support_level", "notes"],
        "properties": {
          "claim": { "type": "string" },
          "paper_location": { "type": "string" },
          "support_level": {
            "type": "string",
            "enum": ["well_supported", "partially_supported", "unsupported", "unclear"]
          },
          "notes": { "type": "string" }
        }
      }
    },
    "technical_objections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "objection",
          "paper_location",
          "evidence",
          "severity",
          "confidence",
          "would_change_verdict_if_true"
        ],
        "properties": {
          "objection": { "type": "string" },
          "paper_location": { "type": "string" },
          "evidence": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["minor", "moderate", "major", "fatal"]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "would_change_verdict_if_true": { "type": "boolean" }
        }
      }
    },
    "missing_assumptions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["assumption", "paper_location", "why_it_matters"],
        "properties": {
          "assumption": { "type": "string" },
          "paper_location": { "type": "string" },
          "why_it_matters": { "type": "string" }
        }
      }
    },
    "novelty_assessment": { "type": "string" },
    "recommended_verdict": {
      "type": "string",
      "enum": [
        "strong_select",
        "promising",
        "routine",
        "weak_evidence",
        "major_flaw",
        "contested"
      ]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "followup_notes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changes_from_prior_cycle",
        "valid_points_from_other_reviewers",
        "invalid_points_from_other_reviewers"
      ],
      "properties": {
        "changes_from_prior_cycle": { "type": "string" },
        "valid_points_from_other_reviewers": {
          "type": "array",
          "items": { "type": "string" }
        },
        "invalid_points_from_other_reviewers": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "needs_human_spotcheck": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["question", "why_model_cannot_resolve"],
        "properties": {
          "question": { "type": "string" },
          "why_model_cannot_resolve": { "type": "string" }
        }
      }
    },
    "overall_score_10": { "type": "number", "minimum": 0, "maximum": 10 },
    "dimension_scores": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "technical_soundness",
        "novelty",
        "significance",
        "clarity",
        "reviewer_confidence"
      ],
      "properties": {
        "technical_soundness": { "type": "number", "minimum": 0, "maximum": 10 },
        "novelty": { "type": "number", "minimum": 0, "maximum": 10 },
        "significance": { "type": "number", "minimum": 0, "maximum": 10 },
        "clarity": { "type": "number", "minimum": 0, "maximum": 10 },
        "reviewer_confidence": { "type": "number", "minimum": 0, "maximum": 10 }
      }
    },
    "score_rationale": {
      "type": "string"
    }
  }
}
